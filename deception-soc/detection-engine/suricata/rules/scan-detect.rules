# =============================================================================
# DECEPTION-SOC: Suricata Detection Rules
# Purpose: Detect attacker activity and trigger deception workflows
# =============================================================================

# -----------------------------------------------------------------------------
# SID 1000001: Nmap SYN Scan Detection
# Detects rapid SYN packets from a single source (20+ in 5 seconds)
# -----------------------------------------------------------------------------
alert tcp any any -> $HOME_NET any (msg:"DECEPTION - Nmap SYN Scan Detected"; \
    flags:S,12; \
    threshold: type both, track by_src, count 20, seconds 5; \
    classtype:attempted-recon; \
    sid:1000001; rev:1;)

# -----------------------------------------------------------------------------
# SID 1000002: Service Version Probe Detection
# Detects SSH banner grabbing / service probing
# -----------------------------------------------------------------------------
alert tcp any any -> $HOME_NET 22 (msg:"DECEPTION - Service Version Probe Detected"; \
    flow:established,to_server; \
    content:"SSH-"; \
    threshold: type both, track by_src, count 5, seconds 10; \
    classtype:attempted-recon; \
    sid:1000002; rev:1;)

# -----------------------------------------------------------------------------
# SID 1000003: SSH Brute Force Detection
# Detects multiple SSH connection attempts (5+ in 60 seconds)
# -----------------------------------------------------------------------------
alert tcp any any -> $HOME_NET 22 (msg:"DECEPTION - SSH Brute Force Detected"; \
    flags:S,12; \
    flow:stateless; \
    threshold: type both, track by_src, count 5, seconds 60; \
    classtype:attempted-admin; \
    sid:1000003; rev:1;)

# -----------------------------------------------------------------------------
# SID 1000004: HTTP Directory Enumeration Detection
# Detects high-volume HTTP requests (30+ in 10 seconds)
# -----------------------------------------------------------------------------
alert http any any -> $HOME_NET any (msg:"DECEPTION - HTTP Directory Enumeration Detected"; \
    flow:established,to_server; \
    threshold: type both, track by_src, count 30, seconds 10; \
    classtype:web-application-attack; \
    sid:1000004; rev:1;)

# -----------------------------------------------------------------------------
# SID 1000005: SQL Injection Detection
# Detects UNION SELECT patterns in HTTP traffic
# -----------------------------------------------------------------------------
alert http any any -> $HOME_NET any (msg:"DECEPTION - SQL Injection Attempt Detected"; \
    flow:established,to_server; \
    content:"UNION"; nocase; \
    content:"SELECT"; nocase; \
    classtype:web-application-attack; \
    sid:1000005; rev:1;)
